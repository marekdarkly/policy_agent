# LaunchDarkly Configuration (Required)
LAUNCHDARKLY_ENABLED=true
LAUNCHDARKLY_SDK_KEY=sdk-your-sdk-key-here
LAUNCHDARKLY_PROJECT_KEY=your-project-key
LAUNCHDARKLY_ACCESS_TOKEN=api-your-access-token-here

# LLM Provider Configuration
LLM_PROVIDER=bedrock
LLM_MODEL=claude-3-5-sonnet

# AWS Configuration (for Bedrock)
AWS_REGION=us-east-1
AWS_PROFILE=default

# Bedrock Knowledge Base IDs (Optional - for RAG)
BEDROCK_POLICY_KB_ID=
BEDROCK_PROVIDER_KB_ID=

# API Keys (required if using OpenAI/Anthropic directly)
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
